        // Send data to your FastAPI backend
        const serverUrl = "https://fastapi-app-540067385489.us-central1.run.app";  // Your production domain
        const submitUrl = serverUrl + "/submit-form";
        console.log("Submitting to URL:", submitUrl);
        
        fetch(submitUrl, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          mode: "cors",
          credentials: "include",
          body: JSON.stringify({
            email: email,
            timestamp: new Date().toISOString(),
            result: resultText || "No significant indicators found.",
            selectedCheckboxes: selectedCheckboxes,
            firstName: document.getElementById("firstName").value
          })
        })
        .then(async response => {
          console.log("Response status:", response.status);
          console.log("Response headers:", Object.fromEntries(response.headers.entries()));
          console.log("Response URL:", response.url);
          
          // First check if the response is ok
          if (!response.ok) {
            const contentType = response.headers.get("content-type");
            console.log("Error response content-type:", contentType);
            
            if (contentType && contentType.includes("application/json")) {
              const errorData = await response.json();
              throw new Error(errorData.detail || `HTTP error! status: ${response.status}`);
            } else {
              const text = await response.text();
              console.error("Non-JSON error response:", text);
              throw new Error(`Server error: ${response.status} ${response.statusText}`);
            }
          }
          
          // Then check content type
          const contentType = response.headers.get("content-type");
          console.log("Success response content-type:", contentType);
          
          if (!contentType || !contentType.includes("application/json")) {
            const text = await response.text();
            console.error("Non-JSON success response:", text);
            throw new Error("Server returned non-JSON response");
          }
          
          // Parse JSON
          const data = await response.json();
          return data;
        })
        .then(data => {
          console.log("Server response:", data);
          // Always show the result text
          resultDiv.innerText = resultText;
          document.getElementById("contactButton").style.display = meetsAny ? "block" : "none";
        })
        .catch(error => {
          console.error("Error submitting form:", error);
          resultDiv.innerText = `There was an error submitting your responses: ${error.message}\n\n${resultText}`;
          // Show contact button if criteria met, even if submission failed
          document.getElementById("contactButton").style.display = meetsAny ? "block" : "none";
        });

      } catch (error) {
        console.error("Error in form evaluation:", error);
        alert("There was an error processing your responses. Please try again.");
      }
    }

    // Add this to prevent any jQuery-related errors from affecting your code
    window.addEventListener('error', function(event) {
      // If the error is from jQuery, prevent it from stopping execution
      if (event.error && event.error.stack && event.error.stack.includes('jquery')) {
        event.preventDefault();
        console.warn('Suppressed jQuery error:', event.error);
      }
    });

    function contactTherapist() {
      const resultText = document.getElementById("result").innerText;
      localStorage.setItem("userDiagnosis", resultText);
      window.location.href = "https://shanebruce.com/new_client/";
    }
